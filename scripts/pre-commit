#!/usr/bin/env bash
# scripts/pre-commit
#
# Local pre-commit hook installed by scripts/bootstrap.sh. Mirrors the CI workflow
# clang-style gate: enforce formatting + run tests before pushing.
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

# Format (when available; CI installs this).
if command -v swift-format >/dev/null 2>&1; then
    swift-format lint --recursive desktop-pet-core
fi

# Tests (only if XCTest is available — see acceptance.md row 29 footnote).
if command -v swift >/dev/null 2>&1; then
    if ! swift test --package-path desktop-pet-core 2>&1 | grep -qE 'Test Suite.*[Ss]ucceeded|Test Suite.*[Pp]assed|Executed [0-9]+ test'; then
        echo "pre-commit: swift test did not surface success — aborting commit."
        echo "  (On macOS without Xcode.app installed, install Xcode or run via CI.)"
        exit 1
    fi
fi
